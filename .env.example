# Public analytics configuration. VITE_ values are exposed to the browser.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Server-side secrets. Copy this file to .env.local and fill in local values.
RAPIDAPI_KEY=
# Keep disabled unless this environment is intentionally allowed to spend OCR quota.
SUDOKU_OCR_ENABLED=false
# Best-effort per-instance abuse brake; enable only after confirming a provider hard cap.
SUDOKU_OCR_MAX_CALLS_PER_IP_PER_HOUR=3
